{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "stigmergy hook codex-claim-stop",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "stigmergy hook codex-mail-notify",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "stigmergy hook codex-claim-warn",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "stigmergy hook codex-session-start",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "stigmergy hook codex-mail-notify",
            "type": "command"
          }
        ]
      }
    ]
  }
}
