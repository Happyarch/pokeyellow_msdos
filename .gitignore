# compiled objects
*.o

# compiled graphics
*.1bpp
*.2bpp
*.pic

# compiled audio
*.pcm

# compiled roms
*.gbc
*.gb
*.patch

# rgbds extras
*.map
*.sym

# tool binaries (pret)
*.exe
*.EXE

# DOS port build artifacts and test helpers
dos_port/**/*.o
dos_port/pokeyellow_dos.exe
dos_port/PKMN.EXE
dos_port/CWSDPMI.EXE
dos_port/CWSDPMI.SWP
*.SWP

# DOS port assets — generated .inc are ignored, EXCEPT the ones below that have
# no `make` rule (checked-in generated graphics: fonts, Pikachu/logo/title pics,
# NPC stills, mon icons). They are NOT reproducible by `make assets`, so they must
# stay tracked. (Untracking them silently breaks fresh-checkout builds — see the
# 88c7f98f regression.) Use `dos_port/assets/*` so git still descends to negate.
dos_port/assets/*
!dos_port/assets/font_1bpp.inc
!dos_port/assets/font_extra_2bpp.inc
!dos_port/assets/font_battle_extra_2bpp.inc
!dos_port/assets/gamefreak_inc_2bpp.inc
!dos_port/assets/mon_icons.inc
!dos_port/assets/nine_2bpp.inc
!dos_port/assets/npc_fisher_still.inc
!dos_port/assets/npc_girl_still.inc
!dos_port/assets/npc_oak_still.inc
!dos_port/assets/pika_bubble_tilemap.inc
!dos_port/assets/pikachu_bg_2bpp.inc
!dos_port/assets/pikachu_ob_2bpp.inc
!dos_port/assets/pikachu_tilemap.inc
!dos_port/assets/pokemon_logo_2bpp.inc
!dos_port/assets/pokemon_logo_corner_2bpp.inc
!dos_port/assets/pokemon_logo_tilemap.inc
!dos_port/assets/title_copyright_2bpp.inc
# UI layout sidecars: hand-positioned via tools/ui_layout/editor.py — the
# source of truth the generated ui_layout_*.inc is derived from. Must stay
# tracked; the .inc itself regenerates via `make assets`.
!dos_port/assets/ui_layout_*_sidecar.json
# Colorization sidecar: human-authored deltas; the generated .inc stays ignored.
!dos_port/assets/colors/
!dos_port/assets/colors/palettes.json
!dos_port/assets/colors/repaint/
!dos_port/assets/colors/repaint/*.png
!dos_port/assets/colors/repaint/*.2bpp

# ARR reference docs (MIDI/SoundBlaster/MT-32 specs) — cannot be committed
docs/sound/

# DOS save files
*.dsv

# MCP debugger: clone and binary are not committed (too large)
dos_port/tools/dosbox-x-mcp/

# mGBA fidelity-harness build output (source is the tools/mgba submodule)
dos_port/tools/mgba_build/

# Claude Code session data (settings.local.json, worktrees, etc.) — but keep
# shared project skills under version control.
.claude/*
!.claude/skills/

# precompiled python
*.pyc
*$py.class

# save game files
*.sgm
*.sav
*.rtc
*.sn*
*.sa*
*.sg1

# ARR score transcriptions
docs/references/pokemon_score_transcriptions/
pokemon_score_descriptions/

# Generated per-song analysis (music_analysis.py output — regenerable)
dos_port/tools/audio/analysis/
