#!/usr/bin/env python3
"""Generate repository-derived pret-label provider/linkage state.

This is an evidence report, not a status database.  It refreshes translation.db,
asks GNU Make itself which sources link (buildprobe), and emits one record per
pret label. Static reachability starts at the shipping `start` symbol over the
build-active port call graph — explicit call/jmp/jcc edges plus proven
fall-through boundaries; runtime execution remains unknown until
scenario-marker evidence exists.

WHAT `reachability` PROVES, AND WHAT IT DOES NOT

  statically-reached-from-start   name-level static analysis finds a path from
                                  `start` in this build's graph, ASSUMING every
                                  call returns. Not evidence of execution.
  not-proven-reached              this analysis found no such path. THIS IS NOT
                                  PROOF OF UNREACHABILITY — see the gaps below.
  not-applicable                  the label's provider does not link.

Known gaps, each a source of residual false negatives:
  * `dd Label` dispatch tables and address-taken operands produce no edge, so
    every jump-table handler and both interrupt handlers (the PIT and keyboard
    ISRs, installed by address) are provably live at runtime yet permanently
    not-proven-reached here.
  * labels/calls inside %include'd files and %macro expansions are not graph
    content.
  * the graph is name-keyed: duplicate definitions of one name union their
    out-edges, so a label can read as reached via its namesake's callers.

An `unreachable`/`no caller` claim therefore needs runtime evidence; this
column can support the positive direction only.
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys
from pathlib import Path

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)
import buildprobe  # noqa: E402  (same-directory helper, shared with update_label_db)

PORT = os.path.dirname(HERE)
DB = os.path.join(HERE, "translation.db")
MAKEFILE = os.path.join(PORT, "Makefile")
ALLOWLIST = os.path.join(HERE, "pret_label_allowlist.json")
ROOT = Path(PORT).parent


def active_plans():
    records = []
    for path in sorted((ROOT / 'docs').glob('current_plan_*.md')):
        text = path.read_text(encoding='utf-8', errors='replace')
        title = next((line[2:].strip() for line in text.splitlines()
                      if line.startswith('# ')), path.stem)
        done = len(re.findall(r'^\s*- \[x\]', text, re.M | re.I))
        open_items = len(re.findall(r'^\s*- \[ \]', text, re.M))
        records.append({'path': str(path.relative_to(ROOT)), 'title': title,
                        'completed': done, 'open': open_items})
    return records


def source_sets():
    """(linked, check-only) — resolved by GNU Make, not by regexing it.

    The regex version this replaces ignored Make conditionals, so it reported
    src/debug/debug_dump.asm (Makefile ifdef NEED_DEBUG_DUMP) and
    src/debug/perf.asm (ifdef DEBUG_PERF) as linked in the default build. They
    are not. LINK_SRCS is what links; ALL_SRCS additionally holds the
    check-only sources (BATTLE_SRCS is deliberately not linked).
    """
    cfg = buildprobe.probe()
    return set(cfg.link), set(cfg.check)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("labels", nargs="*")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--no-scan", action="store_true")
    ap.add_argument("--plans", action="store_true",
                    help="list active plans from docs/current_plan_*.md")
    args = ap.parse_args()
    if args.plans:
        if args.labels:
            ap.error('--plans does not accept labels')
        plans = active_plans()
        if args.json:
            json.dump(plans, sys.stdout, indent=2)
            print()
        else:
            print('plan\tcompleted\topen\ttitle')
            for plan in plans:
                print(f"{plan['path']}\t{plan['completed']}\t{plan['open']}\t{plan['title']}")
        return
    if not args.no_scan:
        subprocess.run([sys.executable, os.path.join(HERE, "update_label_db")], check=True)
    linked, check = source_sets()
    with open(ALLOWLIST, encoding="utf-8") as fh:
        allow = json.load(fh)
    relocated_files = allow.get("relocated_files", {})
    relocated_labels = allow.get("relocated_labels", {})
    con = sqlite3.connect(DB)
    con.row_factory = sqlite3.Row
    where, params = "WHERE l.pret_file IS NOT NULL", []
    if args.labels:
        where += " AND l.name IN (%s)" % ",".join("?" * len(args.labels))
        params = args.labels
    rows = con.execute(f"SELECT l.* FROM labels l {where} ORDER BY l.name", params).fetchall()
    all_labels = con.execute("SELECT * FROM labels").fetchall()
    providers = {r['name']: r['port_file'] or r['stub_file'] for r in all_labels}
    # Build facts only: a call inside an %ifdef the shipping build never
    # assembles is a source fact (label_status --callers keeps it) but not an
    # edge of this build's graph. 'fallthrough' rows are proven boundaries and
    # count exactly like explicit edges — regardless of kind.
    calls = con.execute("SELECT caller, callee FROM calls "
                        "WHERE side='port' AND build_active=1").fetchall()
    graph, callers = {}, {}
    for caller, callee in calls:
        caller_provider = providers.get(caller)
        if caller_provider in linked:
            callers.setdefault(callee, set()).add(caller)
            if providers.get(callee) in linked:
                graph.setdefault(caller, set()).add(callee)
    reachable, pending = set(), ['start']
    while pending:
        node = pending.pop()
        if node in reachable:
            continue
        reachable.add(node)
        pending.extend(graph.get(node, ()))
    records = []
    for row in rows:
        provider = row["port_file"] or row["stub_file"]
        if row["status"] == "missing":
            provider_type = linkage = "missing"
        elif row["status"] == "stub":
            provider_type = "stub"
            linkage = "linked" if provider in linked else "check-only" if provider in check else "unlisted"
        else:
            provider_type = "relocated" if row["status"] == "relocated" else "implementation"
            linkage = "linked" if provider in linked else "check-only" if provider in check else "unlisted"
        deviation = None
        if row["status"] == "relocated":
            deviation = relocated_labels.get(row["name"]) or relocated_files.get(row["pret_file"])
        records.append({
            "label": row["name"], "pret_file": row["pret_file"],
            "provider": provider, "provider_type": provider_type,
            "linkage": linkage, "linked_callers": len(callers.get(row['name'], ())),
            # Names say exactly what the analysis proves. "static-live-entry"
            # and "not-statically-reached" both overclaimed, and the negative
            # was read as "unreachable" in at least two sessions.
            "reachability": ("statically-reached-from-start" if row['name'] in reachable
                             else "not-proven-reached" if linkage == "linked"
                             else "not-applicable"),
            "debug_reachability": "unknown",
            "coverage": [], "deviation": deviation,
        })
    if args.json:
        json.dump(records, sys.stdout, indent=2)
        print()
    else:
        print("label\tprovider_type\tlinkage\tcallers\treachability\tprovider")
        for r in records:
            print("{label}\t{provider_type}\t{linkage}\t{linked_callers}\t{reachability}\t{provider}".format(**r))


if __name__ == "__main__":
    main()
