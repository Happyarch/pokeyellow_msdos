#!/usr/bin/env python3
"""Generate repository-derived pret-label provider/linkage state.

This is an evidence report, not a status database.  It refreshes translation.db,
derives shipping/check-only membership from the Makefile source lists, and emits
one record per pret label.  Reachability and runtime execution are deliberately
reported as unknown until linker-map and scenario-marker evidence exist.
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
PORT = os.path.dirname(HERE)
DB = os.path.join(HERE, "translation.db")
MAKEFILE = os.path.join(PORT, "Makefile")
ALLOWLIST = os.path.join(HERE, "pret_label_allowlist.json")


def source_sets():
    text = open(MAKEFILE, encoding="utf-8").read()
    assignments = {}
    current = None
    for raw in text.splitlines():
        m = re.match(r"^([A-Z][A-Z0-9_]*)\s*(?::|\+)?=\s*(.*)$", raw)
        if m:
            current = m.group(1)
            assignments.setdefault(current, [])
            tail = m.group(2)
        elif current and raw[:1].isspace():
            tail = raw
        else:
            current = None
            continue
        assignments[current].extend(re.findall(r"(?:boot|src)/[^\s\\]+\.asm", tail))
        if not raw.rstrip().endswith("\\"):
            current = None
    linked_vars = {"BOOT_SRCS", "HOME_SRCS", "HAL_SRCS", "SAVE_SRCS",
                   "AUDIO_SRCS", "GAME_SRCS", "POKEMON_SRCS", "ITEMS_SRCS",
                   "FRONTEND_SRCS", "BATTLE_SUPPORT_SRCS"}
    linked = {"dos_port/" + p for v in linked_vars for p in assignments.get(v, [])}
    check_vars = {v for v in assignments if v.endswith("_CHECK_SRCS")} | {"BATTLE_SRCS"}
    check = {"dos_port/" + p for v in check_vars for p in assignments.get(v, [])} - linked
    return linked, check


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("labels", nargs="*")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("--no-scan", action="store_true")
    args = ap.parse_args()
    if not args.no_scan:
        subprocess.run([sys.executable, os.path.join(HERE, "update_label_db")], check=True)
    linked, check = source_sets()
    with open(ALLOWLIST, encoding="utf-8") as fh:
        allow = json.load(fh)
    relocated_files = allow.get("relocated_files", {})
    relocated_labels = allow.get("relocated_labels", {})
    con = sqlite3.connect(DB)
    con.row_factory = sqlite3.Row
    where, params = "WHERE l.pret_file IS NOT NULL", []
    if args.labels:
        where += " AND l.name IN (%s)" % ",".join("?" * len(args.labels))
        params = args.labels
    rows = con.execute(f"""
        SELECT l.*, COUNT(DISTINCT c.caller) AS port_callers
        FROM labels l LEFT JOIN calls c ON c.callee=l.name AND c.side='port'
        {where} GROUP BY l.name ORDER BY l.name""", params).fetchall()
    records = []
    for row in rows:
        provider = row["port_file"] or row["stub_file"]
        if row["status"] == "missing":
            provider_type = linkage = "missing"
        elif row["status"] == "stub":
            provider_type = "stub"
            linkage = "linked" if provider in linked else "check-only" if provider in check else "unlisted"
        else:
            provider_type = "relocated" if row["status"] == "relocated" else "implementation"
            linkage = "linked" if provider in linked else "check-only" if provider in check else "unlisted"
        deviation = None
        if row["status"] == "relocated":
            deviation = relocated_labels.get(row["name"]) or relocated_files.get(row["pret_file"])
        records.append({
            "label": row["name"], "pret_file": row["pret_file"],
            "provider": provider, "provider_type": provider_type,
            "linkage": linkage, "linked_callers": row["port_callers"],
            "reachability": "unknown", "debug_reachability": "unknown",
            "coverage": [], "deviation": deviation,
        })
    if args.json:
        json.dump(records, sys.stdout, indent=2)
        print()
    else:
        print("label\tprovider_type\tlinkage\tcallers\treachability\tprovider")
        for r in records:
            print("{label}\t{provider_type}\t{linkage}\t{linked_callers}\t{reachability}\t{provider}".format(**r))


if __name__ == "__main__":
    main()
