#!/usr/bin/env python3
"""
lint_pret_labels — pret-label convention linter (fidelity plan Stage 2.1).

Runs update_label_db (unless --no-scan), then reports violations as queries
over the labels / port_defs / externs tables in translation.db. Exit 1 if any
unsuppressed violation remains.

Violation classes:
  mirror        pret-named global defined neither in its path-mirrored file
                (dos_port/src/<pret path>) nor covered by the relocation
                allowlist — a relocated-candidate or a silently-patched label.
  non_ret_stub  a *_stubs.asm body that isn't ret-only (calls something, or
                grew past a minimal flag/CF contract) — the "silently patched
                instead of stubbed" GetName class.
  dup_def       one global defined in 2+ port files — the silent-shadow trap
                (a stub linked while the real body sits in a check-only list).
  stale_extern  an `extern` trailing comment naming a *_stubs.asm that no
                longer defines the symbol (stub retired, comment not repointed
                — stub convention rule 3/5).
  call_into_data a port code-flow reference (call/jmp/jcc) whose target is a
                symbol defined in a DATA section (.data/.rodata/.bss) — i.e. a
                data table called as if it were a routine. Assembles + links
                clean and faithdiff-matches by name, but jumps into .data at
                runtime → executes table bytes → page fault. (This is the
                `call IndexToPokedex` crash; IndexToPokedex is a flat table in
                the port, not pret's predef routine.)
  local_shadow  a pret label has a non-global definition outside its selected
                provider, making searches and static call attribution ambiguous.
  weak_relocation a file-level relocation has boilerplate evidence or does not
                actually cover every translated pret label in that file.
  annotation    a structured exception annotation is malformed, uses an unknown
                class, or omits evidence/retirement metadata. Legacy free-form
                annotations remain accepted until touched.
  stale_provider an explicit `src/...asm` extern-provider trail does not define
                that symbol. Enforced by --strict-claims during legacy migration.

Suppressions live in dos_port/tools/pret_label_allowlist.json:
  "suppress": [ {"rule": "<class>", "key": "<label | file:symbol>", "why": "…"} ]
Relocations are not suppressions — they go in relocated_files/relocated_labels
(consumed by update_label_db → status 'relocated').

Usage:  dos_port/tools/lint_pret_labels [--no-scan] [--db PATH]
"""

import argparse
import json
import os
import re
import sqlite3
import subprocess
import sys

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH    = os.path.join(SCRIPT_DIR, 'translation.db')
ALLOWLIST  = os.path.join(SCRIPT_DIR, 'pret_label_allowlist.json')

# A stub body beyond this many instructions (or containing a call/jmp) is no
# longer "ret-only + minimal flag/CF contract".
STUB_MAX_INSTRS = 8
ANNOTATION_RE = re.compile(r';\s*(DEVIATION|STUB|BUG|GLITCH)\{([^}]*)\}')
ANNOTATION_KINDS = {'DEVIATION', 'STUB', 'BUG', 'GLITCH'}
ANNOTATION_CLASSES = {
    'HAL', 'banking', 'projection', 'data-model', 'timing', 'stub', 'temporary'
}
ANNOTATION_FIELDS = {'class', 'pret', 'behavior', 'evidence', 'lifetime'}


def parse_annotation(text):
    """Return (kind, fields, errors) for one structured annotation."""
    m = ANNOTATION_RE.search(text)
    if not m:
        return None
    kind, body = m.group(1), m.group(2)
    fields, errors = {}, []
    for part in body.split(';'):
        if '=' not in part:
            errors.append(f"field lacks '=': {part.strip()!r}")
            continue
        key, value = (x.strip() for x in part.split('=', 1))
        if not key or not value:
            errors.append(f"empty key/value: {part.strip()!r}")
        elif key in fields:
            errors.append(f"duplicate field {key!r}")
        else:
            fields[key] = value
    missing = sorted(ANNOTATION_FIELDS - fields.keys())
    if missing:
        errors.append('missing ' + ', '.join(missing))
    if fields.get('class') not in ANNOTATION_CLASSES:
        errors.append(f"unknown class {fields.get('class')!r}")
    if kind == 'STUB' and fields.get('class') not in {'stub', 'temporary'}:
        errors.append('STUB class must be stub or temporary')
    if kind == 'STUB' and 'label' not in fields:
        errors.append('STUB requires label')
    if kind == 'GLITCH' and 'safety' not in fields:
        errors.append('GLITCH requires safety')
    return kind, fields, errors

def load_suppressions():
    if not os.path.exists(ALLOWLIST):
        return set()
    with open(ALLOWLIST, encoding='utf-8') as fh:
        allow = json.load(fh)
    return {(s['rule'], s['key']) for s in allow.get('suppress', [])}

def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument('--no-scan', action='store_true',
                    help='lint the existing DB without rescanning the tree')
    ap.add_argument('--db', default=DB_PATH)
    ap.add_argument('--strict-claims', action='store_true',
                    help='enforce legacy claim/relocation migration rules')
    args = ap.parse_args()

    if not args.no_scan:
        r = subprocess.run([sys.executable,
                            os.path.join(SCRIPT_DIR, 'update_label_db'),
                            '--db', args.db])
        if r.returncode != 0:
            sys.exit('lint_pret_labels: scan failed')

    suppress = load_suppressions()
    con = sqlite3.connect(args.db)
    cur = con.cursor()
    findings = []      # (rule, key, message)
    suppressed = 0

    def add(rule, key, msg):
        nonlocal suppressed
        if (rule, key) in suppress:
            suppressed += 1
        else:
            findings.append((rule, key, msg))

    # ── mirror: translated at a non-mirrored path, not allowlisted ─────────
    for name, pret_file, port_file in cur.execute("""
            SELECT name, pret_file, port_file FROM labels
            WHERE status='translated'
              AND port_file != 'dos_port/src/' || pret_file
            ORDER BY pret_file, name"""):
        add('mirror', name,
            f"{name}: pret {pret_file} -> {port_file} "
            f"(expected dos_port/src/{pret_file}; allowlist if deliberate)")

    # ── non_ret_stub ────────────────────────────────────────────────────────
    for name, file, line, n, has_call in cur.execute("""
            SELECT name, file, line, instr_count, has_call FROM port_defs
            WHERE is_stub=1 AND defined_here=1
              AND (has_call=1 OR instr_count > ?)
            ORDER BY file, line""", (STUB_MAX_INSTRS,)):
        why = 'contains call/jmp' if has_call else f'{n} instructions'
        add('non_ret_stub', name,
            f"{name} ({file}:{line}): stub body isn't ret-only ({why})")

    # ── dup_def: same global defined in 2+ files ────────────────────────────
    for name, files in cur.execute("""
            SELECT name, GROUP_CONCAT(file, '  ') FROM port_defs
            WHERE is_global=1
            GROUP BY name HAVING COUNT(DISTINCT file) > 1
            ORDER BY name"""):
        add('dup_def', name, f"{name}: defined in {files}")

    # ── call_into_data: code-flow reference to a data-section symbol ────────
    # (a data table called/jumped-to as a routine → runtime jump into .data).
    for caller, callee, kind, file, line in cur.execute("""
            SELECT c.caller, c.callee, c.kind, c.file, c.line
            FROM calls c JOIN port_defs d ON d.name = c.callee
            WHERE c.side = 'port'
              AND d.section IN ('.data','.rodata','.rdata','.bss','.data.rel','.rel')
            GROUP BY c.file, c.line, c.callee
            ORDER BY c.file, c.line"""):
        add('call_into_data', f'{file}:{line}:{callee}',
            f"{file}:{line}: {kind} {callee} — {callee} is defined in a DATA "
            f"section (index the table inline instead of calling it as a routine)")

    # ── stale_extern: comment names a stubs file that doesn't define it ─────
    stub_defs = {(os.path.basename(f), n) for n, f in cur.execute(
        "SELECT name, file FROM port_defs WHERE is_stub=1")}
    stub_files = {b for b, _ in stub_defs} | {
        os.path.basename(f) for (f,) in cur.execute(
            "SELECT DISTINCT file FROM port_defs WHERE is_stub=1")}
    for file, symbol, comment, line in cur.execute(
            "SELECT file, symbol, comment, line FROM externs "
            "WHERE comment LIKE '%_stubs.asm%' ORDER BY file, line"):
        m = re.search(r'([A-Za-z0-9_]+_stubs\.asm)', comment)
        if not m:
            continue
        base = m.group(1)
        if (base, symbol) not in stub_defs:
            missing = ('file has no such stub' if base in stub_files
                       else 'no such stub file')
            add('stale_extern', f'{file}:{symbol}',
                f"{file}:{line}: extern {symbol} comment points at {base} "
                f"({missing})")

    # Explicit source-provider comments are machine-checkable. Boot providers
    # are excluded until update_label_db scans boot/ definitions too.
    all_defs = {(file, name) for name, file in cur.execute(
                "SELECT name, file FROM port_defs")}
    for file, symbol, comment, line in cur.execute(
            "SELECT file, symbol, comment, line FROM externs "
            "WHERE comment LIKE '%src/%.asm%' ORDER BY file, line"):
        m = re.search(r'((?:src)/[A-Za-z0-9_./-]+\.asm)', comment)
        if not m:
            continue
        provider = 'dos_port/' + m.group(1)
        if args.strict_claims and (provider, symbol) not in all_defs:
            add('stale_provider', f'{file}:{symbol}',
                f"{file}:{line}: extern {symbol} names {provider}, which does not define it")

    # ── local_shadow: another file defines the selected pret label locally ──
    for name, selected, shadow in cur.execute("""
            SELECT l.name, l.port_file, d.file FROM labels l JOIN port_defs d
              ON d.name=l.name
            WHERE l.pret_file IS NOT NULL AND d.is_global=0
              AND l.port_file IS NOT NULL AND d.file != l.port_file
            ORDER BY l.name, d.file"""):
        if args.strict_claims:
            add('local_shadow', f'{shadow}:{name}',
                f"{name}: local pret-label shadow in {shadow}; selected provider is {selected}")

    # ── weak_relocation: reject boilerplate file-level authority ────────────
    if os.path.exists(ALLOWLIST):
        with open(ALLOWLIST, encoding='utf-8') as fh:
            allow = json.load(fh)
        weak = re.compile(r'\b(pre-existing relocation|draft session|all \d+ translated)\b', re.I)
        for pret_file, entry in allow.get('relocated_files', {}).items():
            why = entry.get('why', '')
            if args.strict_claims and (weak.search(why) or len(why) < 80):
                add('weak_relocation', pret_file,
                    f"{pret_file}: file-level relocation lacks substantive per-split evidence: {why!r}")

    # ── structured annotations: strict when present, legacy accepted ────────
    src_root = os.path.normpath(os.path.join(SCRIPT_DIR, '..', 'src'))
    for dirpath, dirnames, filenames in os.walk(src_root):
        dirnames.sort()
        for fn in sorted(filenames):
            if not fn.endswith('.asm'):
                continue
            path = os.path.join(dirpath, fn)
            rel = os.path.relpath(path, os.path.join(SCRIPT_DIR, '..', '..')).replace('\\', '/')
            with open(path, encoding='utf-8', errors='replace') as fh:
                for line_no, text in enumerate(fh, 1):
                    parsed = parse_annotation(text)
                    if not parsed:
                        # An opening brace without a complete annotation is
                        # always malformed; do not let a typo fall back to legacy.
                        if re.search(r';\s*(?:DEVIATION|STUB|BUG|GLITCH)\{', text):
                            add('annotation', f'{rel}:{line_no}',
                                f"{rel}:{line_no}: unterminated structured annotation")
                        continue
                    kind, fields, errors = parsed
                    if kind == 'STUB' and fields.get('label'):
                        status = cur.execute(
                            "SELECT status FROM labels WHERE name=?",
                            (fields['label'],)).fetchone()
                        if status and status[0] != 'stub':
                            errors.append(
                                f"STUB label {fields['label']} has generated status {status[0]}")
                    for error in errors:
                        add('annotation', f'{rel}:{line_no}:{error}',
                            f"{rel}:{line_no}: malformed {kind}: {error}")
    con.close()

    by_rule = {}
    for rule, _, msg in findings:
        by_rule.setdefault(rule, []).append(msg)
    for rule in ('mirror', 'non_ret_stub', 'dup_def', 'call_into_data',
                 'stale_extern', 'stale_provider', 'local_shadow', 'weak_relocation'):
        msgs = by_rule.get(rule, [])
        if msgs:
            print(f"\n== {rule} ({len(msgs)}) ==")
            print('\n'.join('  ' + m for m in msgs))
    msgs = by_rule.get('annotation', [])
    if msgs:
        print(f"\n== annotation ({len(msgs)}) ==")
        print('\n'.join('  ' + m for m in msgs))
    print(f"\nlint_pret_labels: {len(findings)} violation(s), "
          f"{suppressed} suppressed")
    sys.exit(1 if findings else 0)

if __name__ == '__main__':
    main()
